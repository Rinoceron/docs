{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Rhino Asset Capital Docs",
  "colors": {
    "primary": "#C79D3C",
    "light": "#D7B467",
    "dark": "#12294B"
  },
  "favicon": "/images/rhino-favicon.png",
  "logo": {
    "light": "/images/rhino-logo.png",
    "dark": "/images/rhino-logo.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Main website",
        "href": "https://rhino-asset.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Contact",
      "href": "mailto:support@rhino-asset.com"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Business Flow",
            "pages": [
              "index",
              "guides/overview",
              "guides/onboarding-to-party",
              "guides/application-to-origination",
              "guides/servicing-and-balances",
              "guides/delinquency-and-collateral"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Rhino API",
            "pages": [
              "api-reference/rhino/index",
              "api-reference/rhino/stages/onboarding",
              "api-reference/rhino/stages/application",
              "api-reference/rhino/stages/servicing",
              "api-reference/rhino/stages/delinquency",
              "api-reference/rhino/stages/misc-services"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API domain",
          "href": "https://api.rhino-asset.com",
          "icon": "server"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/Rinoceron/docs",
          "icon": "github"
        }
      ]
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Rinoceron/docs",
      "website": "https://rhino-asset.com"
    }
  }
}
